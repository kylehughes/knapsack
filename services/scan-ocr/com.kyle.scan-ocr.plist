<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.kyle.scan-ocr</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/kyle/bin/scan-ocr</string>
  </array>

  <key>WatchPaths</key>
  <array>
    <string>/Users/Shared/Scans</string>
  </array>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/kyle/Library/Logs/scan-ocr.launchd.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/kyle/Library/Logs/scan-ocr.launchd.err.log</string>
</dict>
</plist>
